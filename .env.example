# Nexus Docs — Environment Variables
# Copie este arquivo para .env e preencha com seus valores reais.
# .env está no .gitignore — nunca será commitado.

# ===== Tailscale Mesh IPs =====
TAILSCALE_IP_VALIS={{TAILSCALE_IP_VALIS}}
TAILSCALE_IP_PRIS={{TAILSCALE_IP_PRIS}}
TAILSCALE_IP_UBIK={{TAILSCALE_IP_UBIK}}
TAILSCALE_IP_DECKARD={{TAILSCALE_IP_DECKARD}}

# ===== LAN IPs =====
LAN_IP_VALIS={{LAN_IP_VALIS}}
LAN_IP_PRIS={{LAN_IP_PRIS}}
LAN_IP_UBIK={{LAN_IP_UBIK}}
LAN_IP_ROY={{LAN_IP_ROY}}
LAN_IP_DECKARD={{LAN_IP_DECKARD}}

# ===== Domínios =====
CLOUDFLARE_DOMAIN={{CLOUDFLARE_DOMAIN}}
PERSONAL_DOMAIN={{PERSONAL_DOMAIN}}

# ===== Usuário do sistema =====
LINUX_USER=marcel

# ===== GitHub =====
GITHUB_USER=marceltrindade
